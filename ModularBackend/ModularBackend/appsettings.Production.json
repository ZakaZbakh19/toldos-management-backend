{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Security": {
    "ReuseGraceWindow": "500"
  },
  "RateLimiting": {
    "AuthLoginPermitLimit": 5,
    "AuthRegisterPermitLimit": 3,
    "AuthRefreshPermitLimit": 10,
    "AuthLogoutPermitLimit": 20,
    "AuthPermitLimit": 20
  }
}
