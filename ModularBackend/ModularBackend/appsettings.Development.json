{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Security": {
    "ReuseGraceWindow": "500",
    "MaxAttempts": "5"
  },
  "RateLimiting": {
    "AuthLoginPermitLimit": 50,
    "AuthRegisterPermitLimit": 20,
    "AuthRefreshPermitLimit": 50,
    "AuthLogoutPermitLimit": 100,
    "AuthPermitLimit": 100
  }
}
